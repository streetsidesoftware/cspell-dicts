{
  "name": "@cspell/dict-mime-types",
  "version": "1.0.1",
  "description": "MIME Types dictionary for cspell.",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "cspell",
    "mime",
    "mime-types",
    "media-types",
    "dictionary",
    "spelling"
  ],
  "homepage": "https://github.com/streetsidesoftware/cspell-dicts/blob/main/dictionaries/mime-types#readme",
  "bugs": {
    "url": "https://github.com/streetsidesoftware/cspell-dicts/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/streetsidesoftware/cspell-dicts",
    "directory": "dictionaries/mime-types"
  },
  "license": "MIT",
  "author": "Street Side Software <support@streetsidesoftware.nl>",
  "contributors": [
    "Jason Dent <jason+github@streetsidesoftware.nl>"
  ],
  "exports": {
    ".": "./cspell-ext.json",
    "./cspell": "./cspell-ext.json",
    "./cspell-ext.json": "./cspell-ext.json"
  },
  "files": [
    "dict/mime-types.txt.gz",
    "cspell-ext.json"
  ],
  "scripts": {
    "build": "cspell-tools-cli build",
    "conditional-build": "pnpm run sync && pnpm run postsync && pnpm run build",
    "prepare:dictionary": "pnpm run build",
    "prepublishOnly": "echo pre-publish",
    "sync": "sync-github-files jshttp/mime-db --tag=master --filter \"src/*.*\" --filter LICENSE -o src/mime-db",
    "postsync": "node ./scripts/mime-db-to-txt.mjs",
    "sync:manual": "GITHUB_TOKEN=$(gh auth token) pnpm sync",
    "test": "shx head -n 100 src/mime-types.txt | cspell --dictionary=mime-types stdin"
  },
  "devDependencies": {
    "cspell-dicts-scripts": "workspace:*"
  }
}
